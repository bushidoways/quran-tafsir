# Quran Tafsir - Variabel Lingkungan
# Salin file ini menjadi .env dan sesuaikan nilainya

# Aplikasi
APP_NAME="Quran Tafsir"
APP_VERSION="2.0.0"
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# API Eksternal
QURAN_API_BASE=https://api.quran.com/api/v4
TAFSIR_API_BASE=https://api.quran-tafseer.com
ALQURAN_CLOUD_API=https://api.alquran.cloud/v1

# CORS
ALLOWED_ORIGINS=*
